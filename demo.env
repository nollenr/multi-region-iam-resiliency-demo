# IAM Demo Environment Variables
# Copy this file and configure for your environment

# Database connection string
# The demo checks for these environment variables in order:
#   1. CRDB_URL (preferred - matches CockroachDB Cloud standard)
#   2. DB_URI (alternative)
#   3. Falls back to default if neither is set
#
# Format: cockroachdb://[user]@[host]:[port]/[database]?[options]
# The application_name helps identify connections in DB Console
CRDB_URL=cockroachdb://root@localhost:26257/iam_demo?application_name=iam_demo&sslmode=require

# Note: Region is automatically detected from the database gateway connection
# No need to configure it manually!
